{
  "name": "claude-code-wsl-vs-supervisor-helper",
  "displayName": "Claude Code WSL VS Supervisor Helper",
  "description": "Companion extension for Claude Code WSL VS Supervisor. Focuses VS Code terminals by process PID.",
  "version": "0.1.2",
  "publisher": "cafrog",
  "engines": {
    "vscode": "^1.80.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {},
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . -w",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.4.0"
  }
}
