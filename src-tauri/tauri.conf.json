{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code WSL VS Supervisor",
  "version": "0.1.1",
  "identifier": "com.claude-code-wsl-vs-supervisor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Code WSL VS Supervisor",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 500,
        "decorations": true,
        "resizable": true,
        "theme": "Dark",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": [
          "en-US",
          "fr-FR"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/cafrog/claude-code-wsl-vs-supervisor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGRjY1ODk5MjAwNDA1MzIKUldReUJRUWdtVmoyWDZiRitQZllFb2dMVHMvTjdQWDdyM2hXTmlnT0Q3dC9udXh3QzJLWkdZcW8K"
    }
  }
}
